{
  "id": "scaling-vs-goblins",
  "name": "Scaling: Fighter vs Goblins",
  "description": "Analyzes how Champion and Battlemaster performance scales against increasing numbers of Goblins.",
  "num_simulations": 100,
  "level": 5,
  "variables": {
    "goblin_count": [1, 2, 4, 8, 12],
    "subclass": ["champion", "battlemaster"]
  },
  "teams": [
    {
      "name": "Heroes",
      "members": [
        { "name": "Hero", "type": "fighter", "subclass": "{{subclass}}", "abilities": { "strength": 18, "dexterity": 14, "constitution": 14 } }
      ]
    },
    {
      "name": "Monsters",
      "count": "{{goblin_count}}",
      "template": { "name": "Goblin", "type": "goblin" }
    }
  ]
}
