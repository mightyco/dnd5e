{
  "title": "UI Schema",
  "description": "Defines dynamic UI components and visibility rules for the D&D Simulator",
  "type": "object",
  "properties": {
    "character_fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "label", "type", "zone"],
        "properties": {
          "name": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string", "enum": ["select", "checkbox", "number", "text", "multi-checkbox"] },
          "zone": { "type": "string", "enum": ["basic", "stats", "equipment", "feats"] },
          "options_key": { "type": "string" },
          "dynamic_options": { "type": "boolean" },
          "path": { "type": "string" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "visible_if": {
            "type": "object",
            "properties": {
              "field": { "type": "string" },
              "in": { "type": "array", "items": { "type": "string" } },
              "not_in": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
