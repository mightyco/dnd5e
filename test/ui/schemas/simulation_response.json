{
  "type": "array",
  "items": {
    "type": "object",
    "required": ["teams", "rounds", "winner", "initiative_winner"],
    "properties": {
      "teams": {
        "type": "array",
        "items": { "type": "string" }
      },
      "winner": { "type": ["string", "null"] },
      "initiative_winner": { "type": ["string", "null"] },
      "rounds": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["number", "events"],
          "properties": {
            "number": { "type": "integer" },
            "events": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "type": "string" },
                  "attacker": { "type": "string" },
                  "defender": { "type": "string" },
                  "attack_name": { "type": "string" },
                  "success": { "type": "boolean" },
                  "damage": { "type": "integer" },
                  "is_crit": { "type": "boolean" },
                  "is_dead": { "type": "boolean" },
                  "combatant": { "type": "string" },
                  "resource": { "type": "string" },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "attack_roll": { "type": ["integer", "null"] },
                      "picked_roll": { "type": ["integer", "null"] },
                      "raw_rolls": { "type": ["array", "null"], "items": { "type": "integer" } },
                      "modifier": { "type": ["integer", "null"] },
                      "proficiency_bonus": { "type": "integer" },
                      "target_ac": { "type": ["integer", "null"] },
                      "damage_rolls": { "type": ["array", "null"], "items": { "type": "integer" } },
                      "damage_modifier": { "type": ["integer", "null"] },
                      "current_hp": { "type": "integer" },
                      "max_hp": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
